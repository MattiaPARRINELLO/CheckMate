{
  "manifest_version": 3,
  "name": "CheckMate",
  "version": "1.0.0",
  "description": "Automatise le pointage de présence sur CESAR Emineo",
  "permissions": ["storage", "activeTab", "scripting", "notifications", "tabs"],
  "host_permissions": ["https://cesar.emineo-informatique.fr/*"],
  "action": {
    "default_popup": "popup.html",
    "default_title": "CheckMate"
  },
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["https://cesar.emineo-informatique.fr/*"],
      "js": ["content.js"],
      "run_at": "document_idle"
    }
  ],
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
